NODE_ENV=development

# === MinIO ===
MINIO_ROOT_USER=hubadmin
MINIO_ROOT_PASSWORD=hubsecret123
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET_VIDEOS=hub-videos
MINIO_BUCKET_KEYS=hub-keys
MINIO_BUCKET_UPLOADS=hub-uploads

# === Redis ===
REDIS_PASSWORD=redishub123
REDIS_URL=redis://:redishub123@localhost:6379

# === MongoDB ===
MONGO_USER=hubuser
MONGO_PASSWORD=hubmongo123
MONGO_URI=mongodb://hubuser:hubmongo123@localhost:27017/hub_db?authSource=admin

# === JWT / Session ===
JWT_SECRET=changeme_use_a_256bit_random_secret_in_production
JWT_EXPIRES_IN=1h
SIGNED_URL_SECRET=changeme_signed_url_hmac_secret

# === API ===
API_PORT=4000
INTERNAL_API_URL=http://localhost:4000
